# ─── Django Core ──────────────────────────────────────────────────────────
SECRET_KEY=generate-a-long-random-string-here
DEBUG=False

# Your Railway backend domain (no https://, no trailing slash)
ALLOWED_HOSTS=your-backend-name.up.railway.app

# ─── Database (Railway auto-fills these if using their Postgres plugin) ────
DB_NAME=railway
DB_USER=postgres
DB_PASSWORD=auto-filled-by-railway
DB_HOST=auto-filled-by-railway
DB_PORT=5432

# ─── CORS — MUST be your exact Vercel URL, with https://, no trailing slash ─
CORS_ALLOWED_ORIGINS=https://wolbi-royal-enterprise.vercel.app

# ─── Cloudinary ──────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Email ───────────────────────────────────────────────────────────────
RESEND_API_KEY=your-resend-api-key
DEFAULT_FROM_EMAIL=noreply@wolbiroyal.com
